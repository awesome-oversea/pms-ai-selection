APP_NAME=pms-ai-selection
APP_VERSION=0.1.0
APP_ENVIRONMENT=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_API_PREFIX=/api/v1
APP_HOST_PORT=18000

DB_URL=postgresql+asyncpg://pms:CHANGE_ME@127.0.0.1:5432/pms_db
DATABASE_URL=postgresql+asyncpg://pms:CHANGE_ME@127.0.0.1:5432/pms_db
REDIS_URL=redis://127.0.0.1:6379/3
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092

SEC_SECRET_KEY=replace-with-a-strong-random-secret

LOCAL_TOOL_ROOT=D:/aitools
LOCAL_MODEL_CACHE_DIR=D:/aitools/fms/model-cache
PMS_CACHE_ROOT=D:/aitools/fms/cache
PMS_ARTIFACTS_ROOT=D:/aitools/fms/artifacts
PMS_DATA_ROOT=D:/aitools/shared
PMS_DOCKER_PYTHON_EXTRAS=local-ai

LLM_PRIMARY_MODEL=qwen2.5:1.5b-instruct
LLM_OLLAMA_ENDPOINT=http://127.0.0.1:11434
DOCKER_APP_LLM_OLLAMA_ENDPOINT=http://ollama-shared:11434
LLM_EMBEDDING_MODEL=bge-large-zh

DIFY_ENABLED=false
SEARCH_ENABLED=false
SEARCH_BACKEND=opensearch
SEARCH_ENDPOINT=http://127.0.0.1:19200
NEO4J_ENABLED=false
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change_me_neo4j

QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333

KONG_PROXY_URL=http://127.0.0.1:8000
KONG_ADMIN_URL=http://127.0.0.1:8001
LOCAL_RUNTIME_PROFILE=windows-host
LOCAL_RUNTIME_PREFERRED_OS=windows
LOCAL_RUNTIME_SCENARIO_MODE=local-real
