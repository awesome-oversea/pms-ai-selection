APP_NAME=pms-ai-selection
APP_VERSION=0.1.0
APP_ENVIRONMENT=staging
APP_DEBUG=false
APP_LOG_LEVEL=INFO
APP_API_PREFIX=/api/v1
APP_HOST_PORT=18000

DB_URL=postgresql+asyncpg://pms:pms_dev_2024@postgres-shared:5432/pms_db
DATABASE_URL=postgresql+asyncpg://pms:pms_dev_2024@postgres-shared:5432/pms_db
REDIS_URL=redis://redis-shared:6379/3
KAFKA_BOOTSTRAP_SERVERS=kafka-shared:9092

SEC_SECRET_KEY=replace-with-a-strong-random-secret

LOCAL_TOOL_ROOT=/data/aitools
LOCAL_MODEL_CACHE_DIR=/data/aitools/fms/model-cache
PMS_CACHE_ROOT=/data/aitools/fms/cache
PMS_ARTIFACTS_ROOT=/data/aitools/fms/artifacts
PMS_DATA_ROOT=/data/aitools/shared
PMS_DOCKER_PYTHON_EXTRAS=local-ai

LLM_PRIMARY_MODEL=qwen2.5:1.5b-instruct
LLM_OLLAMA_ENDPOINT=http://127.0.0.1:11434
DOCKER_APP_LLM_OLLAMA_ENDPOINT=http://ollama-shared:11434
LLM_EMBEDDING_MODEL=bge-large-zh

DIFY_ENABLED=false
SEARCH_ENABLED=true
SEARCH_BACKEND=opensearch
SEARCH_ENDPOINT=http://opensearch-shared:9200
NEO4J_ENABLED=false
NEO4J_URI=bolt://neo4j-shared:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change_me_neo4j

QDRANT_HOST=qdrant-shared
QDRANT_PORT=6333

KONG_PROXY_URL=http://127.0.0.1:8000
KONG_ADMIN_URL=http://127.0.0.1:8001
LOCAL_RUNTIME_PROFILE=ecs-compose
LOCAL_RUNTIME_PREFERRED_OS=linux
LOCAL_RUNTIME_SCENARIO_MODE=shared-runtime
