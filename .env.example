APP_NAME=pms-ai-selection
APP_VERSION=0.1.0
APP_ENVIRONMENT=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_API_PREFIX=/api/v1
APP_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
APP_HOST_PORT=18000

DB_URL=postgresql+asyncpg://pms:pms_dev_2024@127.0.0.1:5432/pms_db
DATABASE_URL=postgresql+asyncpg://pms:pms_dev_2024@127.0.0.1:5432/pms_db
DB_WRITE_URL=
DB_READ_URLS=[]
# 透明读写分离：开启后，SELECT 优先走 DB_READ_URLS；写操作固定走 DB_WRITE_URL/DB_URL
DB_READ_WRITE_SPLIT=false
DB_FALLBACK_TO_WRITE_FOR_READS=true
DB_READ_STRATEGY=round_robin
DB_PROBE_TIMEOUT_SECONDS=3
# Docker Compose 中数据库密码（可通过环境变量 POSTGRES_PASSWORD 覆盖）
# POSTGRES_PASSWORD=pms_dev_2024
# P5-03 PostgreSQL HA（WSL + Docker + pgpool + 主从）推荐：
# DB_URL=postgresql+asyncpg://pms:pms_dev_2024@127.0.0.1:15432/pms_db
# DATABASE_URL=postgresql+asyncpg://pms:pms_dev_2024@127.0.0.1:15432/pms_db
# DB_WRITE_URL=postgresql+asyncpg://pms:pms_dev_2024@127.0.0.1:15432/pms_db
# DB_READ_URLS=postgresql+asyncpg://pms:pms_dev_2024@127.0.0.1:15436/pms_db,postgresql+asyncpg://pms:pms_dev_2024@127.0.0.1:15437/pms_db
# DB_READ_WRITE_SPLIT=true
# PGHA_POSTGRES_PASSWORD=postgres_dev_2024
# PGHA_APP_PASSWORD=pms_dev_2024
# PGHA_REPMGR_PASSWORD=repmgr_dev_2024
# PGHA_PGPOOL_ADMIN_PASSWORD=pgpool_admin_2024
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_ECHO_SQL=false

REDIS_URL=redis://127.0.0.1:6379/0
REDIS_CLUSTER_MODE=false
REDIS_CLUSTER_NODES=[]
REDIS_SENTINEL_ENABLED=false
REDIS_SENTINEL_MASTER_NAME=mymaster
REDIS_SENTINEL_NODES=127.0.0.1:26379,127.0.0.1:26380,127.0.0.1:26381
REDIS_SENTINEL_USERNAME=
REDIS_SENTINEL_PASSWORD=
REDIS_SENTINEL_DB=0
REDIS_MAX_CONNECTIONS=20

KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
KAFKA_GROUP_ID=pms-consumer-group
KAFKA_TOPICS_DATA_COLLECTION=pms-data-collection
KAFKA_TOPICS_AGENT_EVENT=pms-agent-event
KAFKA_AUTO_OFFSET_RESET=latest

# ⚠️ 安全提示：production 环境必须使用强随机密钥（≥32 字符），否则应用会拒绝启动。
# 生成方法: python -c "import secrets; print(secrets.token_urlsafe(48))"
SEC_SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_STRONG_RANDOM_KEY_MIN_32_CHARS!!
# 兼容旧键名（仅迁移期保留，不建议继续新增使用）：
# SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_STRONG_RANDOM_KEY_MIN_32_CHARS!!
SEC_ALGORITHM=HS256
SEC_ACCESS_TOKEN_EXPIRE_MINUTES=15
SEC_REFRESH_TOKEN_EXPIRE_DAYS=7
SEC_PASSWORD_MIN_LENGTH=8
SEC_OIDC_ENABLED=false
# Keycloak 示例：SEC_OIDC_ISSUER_URL=http://127.0.0.1:18082/realms/pms-dev
# Okta 示例：SEC_OIDC_ISSUER_URL=https://your-domain.okta.com/oauth2/default
SEC_OIDC_ISSUER_URL=http://127.0.0.1:18082/realms/pms-dev
SEC_OIDC_DISCOVERY_URL=
SEC_OIDC_CLIENT_ID=pms-web
SEC_OIDC_CLIENT_SECRET=pms-secret
SEC_OIDC_JWKS_URI=
SEC_OIDC_AUDIENCE=
SEC_OIDC_SCOPE="openid profile email"
SEC_OIDC_USERNAME_CLAIMS=preferred_username,email,sub
SEC_OIDC_ROLE_CLAIM_PATHS=roles,groups,realm_access.roles,resource_access.{client_id}.roles
SEC_OIDC_ROLE_MAPPING=
SEC_OIDC_TENANT_ID_CLAIM=tenant_id
SEC_OIDC_TENANT_KEY_CLAIM=tenant_key
SEC_OIDC_TENANT_NAME_CLAIM=tenant_name
SEC_OIDC_DEFAULT_TENANT_ID=
SEC_OIDC_DEFAULT_TENANT_KEY=default
SEC_OIDC_DEFAULT_TENANT_NAME=默认租户
SEC_OIDC_HTTP_TIMEOUT_SECONDS=5
SEC_OIDC_CACHE_TTL_SECONDS=300

# 本地重资源统一落盘根目录：不要放在 C 盘
LOCAL_TOOL_ROOT=D:/aitools
LOCAL_OLLAMA_DATA_DIR=D:/aitools/fms/ollama
LOCAL_MODEL_CACHE_DIR=D:/aitools/fms/model-cache

LLM_PRIMARY_MODEL=qwen2.5:1.5b-instruct
# 本地默认：优先使用 WSL/Linux 中启动的 Ollama GGUF 量化模型
# 推荐本地模型矩阵：
# - 文本对话：Qwen2.5-1.5B（Ollama GGUF量化）
# - 多模态/视频：Qwen3.5-2B（Ollama 多模态模型，WSL + Docker Compose）
# - 精排：bge-reranker-base（纯CPU）
# - 语音转录：Whisper tiny（纯CPU）
# 兼容保留：如后续恢复高配路线，可继续指向 vLLM / Triton
LLM_VLLM_ENDPOINT=http://127.0.0.1:8000/v1
LLM_TRITON_ENDPOINT=http://127.0.0.1:8000
# 宿主机 / WSL 直连入口
LLM_OLLAMA_ENDPOINT=http://127.0.0.1:11434
# docker-compose.yml 内的 app 容器默认改走共享网络别名，避免误用容器内 localhost
DOCKER_APP_LLM_OLLAMA_ENDPOINT=http://ollama:11434
LLM_EMBEDDING_MODEL=bge-large-zh
LLM_MULTIMODAL_MODEL=qwen3.5:2b
LLM_RERANK_MODEL=bge-reranker-base
LLM_SPEECH_MODEL=whisper-tiny
LLM_SPEECH_DEVICE=cpu
PMS_DOCKER_PYTHON_EXTRAS=local-ai
LLM_REQUEST_TIMEOUT_SECONDS=30
LLM_REQUEST_RETRY_COUNT=1
LLM_MAX_TOKENS=4096
# 在线 LLM 预留（默认不启用，仅在 SERVICE_MODE_LLM_MODE=remote-service 或显式 real 调用时使用）
LLM_API_KEY=
LLM_API_AUTH_HEADER=Authorization
LLM_API_AUTH_SCHEME=Bearer
LLM_API_MODEL_NAME=

# 服务模式：mock / local-real(WSL) / remote-service 建议通过这些开关切换
# 说明：这些 BASE_URL 在本地 remote-service 联调时默认指向 Kong 代理 `:8000`。
# 如果未启用 Kong，请改为 FastAPI 直连端口（local-real 通常是 `:18000`）。
SERVICE_MODE_RAG_MODE=in-process
SERVICE_MODE_RAG_BASE_URL=http://127.0.0.1:8000/api/v1
SERVICE_MODE_RAG_TIMEOUT_SECONDS=10
SERVICE_MODE_LLM_MODE=in-process
SERVICE_MODE_LLM_BASE_URL=http://127.0.0.1:8000/api/v1
SERVICE_MODE_LLM_TIMEOUT_SECONDS=15
SERVICE_MODE_AGENT_MODE=in-process
SERVICE_MODE_AGENT_BASE_URL=http://127.0.0.1:8000/api/v1
SERVICE_MODE_AGENT_TIMEOUT_SECONDS=10
SERVICE_MODE_EMBEDDING_MODE=in-process
SERVICE_MODE_EMBEDDING_BASE_URL=http://127.0.0.1:8000/api/v1
SERVICE_MODE_EMBEDDING_TIMEOUT_SECONDS=10
SERVICE_MODE_ENABLE_FALLBACK=true

DIFY_ENABLED=false
DIFY_BASE_URL=http://127.0.0.1:58080
DIFY_API_KEY=
DIFY_WORKFLOW_RUN_PATH=/v1/workflows/run
DIFY_TIMEOUT_SECONDS=20
DIFY_RESPONSE_MODE=blocking
DIFY_USER_PREFIX=pms
DIFY_PREFER_COMPATIBLE_FALLBACK=true

# 外部采集 / 真实联调（N2-01 / N2-02）
COLLECTION_API_AMAZON_ENDPOINT=https://sellingpartnerapi-na.amazon.com
COLLECTION_API_AMAZON_API_KEY=
COLLECTION_API_AMAZON_MARKETPLACE=ATVPDKIKX0DER
COLLECTION_API_AMAZON_TIMEOUT_SECONDS=10
COLLECTION_API_TIKTOK_ENDPOINT=https://business-api.tiktok.com
COLLECTION_API_TIKTOK_API_KEY=
COLLECTION_API_TIKTOK_TIMEOUT_SECONDS=10
COLLECTION_API_ALI1688_ENDPOINT=https://api.1688.com
COLLECTION_API_ALI1688_API_KEY=
COLLECTION_API_ALI1688_SECRET_KEY=
COLLECTION_API_ALI1688_TIMEOUT_SECONDS=10
COLLECTION_API_GOOGLE_TRENDS_ENDPOINT=https://trends.google.com
COLLECTION_API_GOOGLE_TRENDS_API_KEY=
COLLECTION_API_GOOGLE_TRENDS_TIMEOUT_SECONDS=10
COLLECTION_API_HTTP_MAX_ATTEMPTS=3
COLLECTION_API_HTTP_BASE_BACKOFF_SECONDS=0.5
COLLECTION_API_HTTP_MAX_BACKOFF_SECONDS=3.0
COLLECTION_API_PROXY_PROVIDER=none
COLLECTION_API_PROXY_LIST=
COLLECTION_API_PROXY_ENDPOINT=
COLLECTION_API_PROXY_USERNAME=
COLLECTION_API_PROXY_PASSWORD=
COLLECTION_API_PROXY_ZONE=
COLLECTION_API_PROXY_COUNTRY=
COLLECTION_API_PROXY_PROBE_URL=https://httpbin.org/ip
COLLECTION_API_PROXY_PROBE_TIMEOUT_SECONDS=8

SEARCH_ENABLED=false
# 本地 Linux / WSL 运行时建议优先使用 opensearch 或 elasticsearch
SEARCH_BACKEND=memory
SEARCH_ENDPOINT=
SEARCH_USERNAME=
SEARCH_PASSWORD=
SEARCH_INDEX_PREFIX=pms_knowledge_
SEARCH_TIMEOUT_SECONDS=15

NEO4J_ENABLED=false
NEO4J_URI=bolt://127.0.0.1:17687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=pms_graph_dev
NEO4J_DATABASE=neo4j
NEO4J_TIMEOUT_SECONDS=5
NEO4J_PREFER_LOCAL_FALLBACK=true

# WSL/Linux 本地依赖建议端口（按需启用）
KONG_PROXY_URL=http://127.0.0.1:8000
KONG_ADMIN_URL=http://127.0.0.1:8001
LOCAL_RUNTIME_PROFILE=windows-host+linux-deps
# allowed: auto / windows / linux / linux-wsl
LOCAL_RUNTIME_PREFERRED_OS=linux-wsl
# allowed: mock / local-real / remote-service
LOCAL_RUNTIME_SCENARIO_MODE=local-real

QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
QDRANT_URL=
QDRANT_WRITE_URL=
QDRANT_READ_URLS=[]
QDRANT_CLUSTER_ENABLED=false
QDRANT_API_KEY=
QDRANT_TIMEOUT_SECONDS=10
QDRANT_PREFER_LOCAL_FALLBACK=true
QDRANT_READ_STRATEGY=round_robin
QDRANT_COLLECTION_PREFIX=pms_
QDRANT_SHARD_NUMBER=1
QDRANT_REPLICATION_FACTOR=1
QDRANT_WRITE_CONSISTENCY_FACTOR=1
# WSL + Docker Qdrant 高可用集群推荐：
# QDRANT_CLUSTER_ENABLED=true
# QDRANT_URL=http://127.0.0.1:16333
# QDRANT_WRITE_URL=http://127.0.0.1:16333
# QDRANT_READ_URLS=http://127.0.0.1:16433,http://127.0.0.1:16533
# QDRANT_SHARD_NUMBER=2
# QDRANT_REPLICATION_FACTOR=2
# QDRANT_WRITE_CONSISTENCY_FACTOR=2
