# 单机 ECS + Ubuntu 22.04 + Docker Compose 开发/测试模板
# 重资源统一放在数据盘，不要落到系统盘。

PMS_DATA_ROOT=/data/pms
PMS_CACHE_ROOT=/data/pms/cache
PMS_ARTIFACTS_ROOT=/data/pms/artifacts
PMS_OLLAMA_ROOT=/data/pms/ollama

PMS_APP_IMAGE=pms-app:dev
PMS_DOCKER_PYTHON_EXTRAS=local-ai

APP_ENVIRONMENT=development
APP_DEBUG=false
APP_LOG_LEVEL=INFO
APP_API_PREFIX=/api/v1
APP_HOST_PORT=18000

KONG_PROXY_PORT=8000
KONG_ADMIN_PORT=8001

POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
QDRANT_HOST_PORT=6333
QDRANT_GRPC_HOST_PORT=6334
SEARCH_HOST_PORT=19200
SEARCH_METRICS_PORT=19600
NEO4J_HTTP_PORT=17474
NEO4J_BOLT_PORT=17687

SEARCH_ENABLED=true
SEARCH_BACKEND=opensearch
SEARCH_TIMEOUT_SECONDS=15

NEO4J_AUTH=neo4j/CHANGE_ME
NEO4J_PASSWORD=CHANGE_ME
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m

LLM_OLLAMA_ENDPOINT=http://ollama:11434
OLLAMA_HOST_PORT=11434

SEC_SECRET_KEY=dev-secret-key-for-testing-only-not-for-production!!
