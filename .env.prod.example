# 生产 MVP 模板
# 建议：
# 1. PostgreSQL / Redis 优先改为云托管。
# 2. 应用层重资源统一放在数据盘 /data/pms。
# 3. 默认不启用本地 GPU LLM，只有在私有化要求明确时才启用 gpu-private-llm profile。

PMS_APP_IMAGE=registry.example.com/pms/app:2026.04.22
PMS_CACHE_ROOT=/data/pms/cache
PMS_ARTIFACTS_ROOT=/data/pms/artifacts
PMS_OLLAMA_ROOT=/data/pms/ollama

APP_ENVIRONMENT=production
APP_DEBUG=false
APP_LOG_LEVEL=INFO
APP_API_PREFIX=/api/v1
APP_HOST_PORT=18000

KONG_PROXY_PORT=8000
KONG_ADMIN_PORT=8001

DB_URL=postgresql+asyncpg://pms:CHANGE_ME@rds-host:5432/pms_db
REDIS_URL=redis://tair-host:6379/0

SEARCH_ENABLED=true
SEARCH_BACKEND=opensearch
SEARCH_ENDPOINT=http://search-host:9200
SEARCH_TIMEOUT_SECONDS=15

QDRANT_HOST=qdrant-host
QDRANT_PORT=6333
QDRANT_URL=

NEO4J_URI=bolt://neo4j-host:7687

LLM_OLLAMA_ENDPOINT=http://ollama:11434
OLLAMA_HOST_PORT=11434

SEC_SECRET_KEY=CHANGE_ME_TO_A_REAL_SECRET_WITH_AT_LEAST_32_CHARS
